{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:inspect": "NODE_OPTIONS=\"--inspect=9229 --enable-source-maps\" tsx src/index.ts",
    "build:watch": "tsc -w --preserveWatchOutput",
    "start:inspect": "NODE_OPTIONS=\"--inspect=9229 --enable-source-maps\" node dist/index.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "ingest": "tsx scripts/ingest-knowledge.ts",
    "rag:debug": "tsx scripts/debug-rag.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
