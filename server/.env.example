# HTTP port for the API server
PORT=3001

# Comma-separated browser origins allowed by CORS (must include your Vite dev URL)
CLIENT_ORIGIN=http://localhost:5173

# Docker: nginx serves UI + /api on one origin (see .env.docker.example at repo root).
# With docker compose, the browser usually does not need CORS because /api is same-origin.

# Optional: real OpenAI chat (omit or leave empty for demo replies)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# ASSISTANT_SYSTEM_PROMPT=You are a helpful assistant...

# Supabase (pgvector RAG) — Project Settings → API
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RAG tuning (default threshold 0.3; lower = more recall)
# RAG_MATCH_THRESHOLD=0.3
# RAG_MATCH_COUNT=5
# RAG_FALLBACK_MIN_SIMILARITY=0.2

# Optional: protect POST /api/admin/ingest (header: X-Ingest-Secret)
# INGEST_SECRET=
