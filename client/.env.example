# Vite dev server port (must match CLIENT_ORIGIN on the server if you change it)
CLIENT_PORT=5173

# Where /api/* requests are proxied during npm run dev
API_PROXY_TARGET=http://localhost:3001

# Docker production stack (from repo root):
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build
# UI: http://localhost:8080  (nginx serves SPA + proxies /api to the API)
